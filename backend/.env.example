# ── Servidor ──────────────────────────────────────────────
PORT=3001

# ── MongoDB ───────────────────────────────────────────────
# URI de conexión a MongoDB (local o Atlas)
MONGODB_URI=mongodb://localhost:27017/agente-ventas

# ── Ollama (LLM local) ────────────────────────────────────
# URL base del servidor Ollama
OLLAMA_BASE_URL=http://localhost:11434
# Modelo a usar (debe estar descargado: ollama pull llama3.1)
OLLAMA_MODEL=llama3.1

# ── CORS ──────────────────────────────────────────────────
# URL del frontend Next.js
FRONTEND_URL=http://localhost:3000

# ── Seguridad ─────────────────────────────────────────────
# Clave para acceder al endpoint admin GET /api/orders
# Si se deja vacío, el endpoint queda abierto (no recomendado en producción)
ADMIN_KEY=cambia_esta_clave_secreta
