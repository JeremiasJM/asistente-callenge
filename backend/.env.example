# ── Servidor ──────────────────────────────────────────────
PORT=3001

# ── MongoDB ───────────────────────────────────────────────
# URI de conexión a MongoDB (local o Atlas)
MONGODB_URI=mongodb://localhost:27017/agente-ventas

# ── OpenAI ────────────────────────────────────────────────
# API Key de OpenAI (obtener en https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-REEMPLAZAR_CON_TU_API_KEY
# Modelo a usar (gpt-4o-mini recomendado para producción, gpt-4o para mayor calidad)
OPENAI_MODEL=gpt-4o-mini

# ── CORS ──────────────────────────────────────────────────
# URL del frontend (en producción: URL de Vercel)
FRONTEND_URL=http://localhost:3000

# ── Seguridad ─────────────────────────────────────────────
# Clave para acceder al endpoint admin GET /api/orders
# Si se deja vacío, el endpoint queda abierto (no recomendado en producción)
ADMIN_KEY=cambia_esta_clave_secreta
